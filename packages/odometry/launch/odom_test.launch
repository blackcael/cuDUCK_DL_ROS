<launch>
    <group ns="odometry_test">
        <node name="test_pub_subscribe" pkg="odometry" type="test_pub_subscribe.py"/>
        <node name="odom_test_pub" pkg="odometry" type="odom_test_pub.py"/>
        <node name="odom_graph" pkg="odometry" type="odom_graph.py"/>

    <arg name="topic_name"     default="pose"/>
    <node 
        pkg="rostopic"
        type="rostopic"
        name="name" 
        args="echo $(arg topic_name)"
        output="screen" />
    </group>
</launch>