<launch>
    <node name="odom_graph" pkg="odometry" type="odom_graph.py"/>
    <node name="test_odom_robot" pkg="odometry" type="test_odom_robot.py"/>

    <arg name="topic_name"     default="pose"/>
    <node 
        pkg="rostopic"
        type="rostopic"
        name="name" 
        args="echo $(arg topic_name)"
        output="screen" />
</launch>